{
   "compilerOptions": {
      "target": "es2015",
      "lib": [
         "dom",
         "dom.iterable",
         "esnext"
      ],
      "skipLibCheck": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "noFallthroughCasesInSwitch": true,
      "module": "esnext",
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "noEmit": false,
      "outDir": "./build",
      "sourceMap": true,
      "declaration": true,
      "isolatedModules": true,
      "baseUrl": ".",
      "paths": {
         "webgl-test-shared": ["../shared/src"]
      }
   },
   "include": ["src", "src/ui-state/nerd-vision-funcs.ts"],
   "exclude": ["node_modules/*", "__sapper__/*", "public/*"]
}