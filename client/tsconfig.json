{
   "compilerOptions": {
      "target": "es2015",
      "lib": [
         "dom",
         "dom.iterable",
         "esnext"
      ],
      "skipLibCheck": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "noFallthroughCasesInSwitch": true,
      "module": "esnext",
      "resolveJsonModule": true,
      "noEmit": false,
      "sourceMap": true,
      "declaration": true,
      "isolatedModules": true,
      "paths": {
         "webgl-test-shared": ["../shared/src"]
      }
   },
   "include": ["src"],
   "exclude": ["node_modules/*", "__sapper__/*", "public/*", "tools/*"]
}