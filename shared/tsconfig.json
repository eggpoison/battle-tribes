{
   "compilerOptions": {
      "target": "esnext",
      "module": "nodenext",
      "moduleResolution": "nodenext",
      "declaration": true,
      "declarationMap": true,
      "outDir": "dist",
      "rootDir": "src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "composite": true
   },
   "include": ["src"]
}