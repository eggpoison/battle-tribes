{
   "compilerOptions": {
      "target": "es2015",
      "lib": [
         "dom",
         "dom.iterable",
         "esnext"
      ],
      "skipLibCheck": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "noFallthroughCasesInSwitch": true,
      "module": "esnext",
      "sourceMap": true,
      "moduleResolution": "bundler",
      "declaration": true,
      "isolatedModules": false
   },
   "references": [
     { "path": "../shared" }
   ],
   "include": ["src"],
   "exclude": ["node_modules/*", "__sapper__/*", "public/*", "tools/*"]
}